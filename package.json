{
  "name": "atom-html",
  "version": "2.0.0",
  "author": "Red Pixel Themes",
  "private": true,
  "homepage": "https://SyedFahad7.github.io/Portfolio/",
  "scripts": {
    "css": "postcss assets/styles/main.css -o build/assets/styles/main.min.css --verbose",
    "server-reload": "browser-sync start --config './browser-sync-config.js'",
    "develop": "concurrently 'npm:css -- --watch' 'npm:server-reload'",
    "build": "npm run css -- --env 'production' && npm run copy-html && npm run copy-assets",
    "copy-html": "powershell -Command Copy-Item -Path '.\\*.html' -Destination '.\\build\\' -Force",
    "copy-assets": "powershell -Command Copy-Item -Path '.\\assets\\*' -Destination '.\\build\\assets\\' -Recurse -Force",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%"
  ],
  "dependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.0",
    "@tailwindcss/forms": "^0.4.0",
    "@tailwindcss/typography": "^0.5.2",
    "browser-sync": "^2.27.7",
    "cssnano": "^5.0.17",
    "postcss-cli": "^9.1.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.39",
    "prettier": "^2.5.1",
    "prettier-plugin-tailwindcss": "^0.1.8",
    "tailwindcss": "^3.4.4"
  }
}
